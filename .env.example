# PORT: Optional server port. Defaults to 3000.
PORT=3000

# NODE_ENV: Render production services should set this to production.
NODE_ENV=production

# BROWSER_EXTENSION_PATHS: Optional Chrome extension folders.
# Separate multiple unpacked extension paths with ";" on Windows or ":" on Linux/macOS.
BROWSER_EXTENSION_PATHS=""

# STREAM_FPS and STREAM_JPEG_QUALITY tune remote browser speed vs. CPU/network use.
STREAM_FPS=6
STREAM_JPEG_QUALITY=35
